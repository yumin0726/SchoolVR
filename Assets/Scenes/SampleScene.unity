  npcPersonality: "\u4F60\u662F\u4E00\u500B\u838A\u56B4\u7684\u4EBA\uFF0C\u73FE\u5728\u662F\u5B9C\u862D\u5927\u5B78\u5C0E\u89BD\u54E1\uFF0C\u8AAA\u8A71\u7C21\u55AE\u3001\u559C\u6B61\u8B1B\u91CD\u9EDE\u3002"
  schoolKnowledge: "\u4E00\u3001 \u9081\u5411\u767E\u5E74\uFF0C\u86FB\u8B8A\u5C55\u7FC5\u8207\u6CBB\u6821\u9858\u666F\r\n\u6DF1\u539A\u6B77\u53F2\u8207\u767C\u5C55\u5B9A\u4F4D\uFF1A\u570B\u7ACB\u5B9C\u862D\u5927\u5B78\u81EA
    1926 \u5E74\u4EE5\u8FB2\u696D\u7ACB\u6821\uFF0C\u64C1\u6709\u8FD1\u767E\u5E74\u6B77\u53F2\u3002\u96A8\u8457\u96EA\u5C71\u96A7\u9053\u958B\u901A\uFF0C\u5B9C\u862D\u8207\u5317\u90E8\u751F\u6D3B\u5708\u7DCA\u5BC6\u76F8\u9023\uFF0C\u5B78\u6821\u4E5F\u5F9E\u50B3\u7D71\u8FB2\u696D\u8DE8\u8DB3\u4F11\u9592\u7522\u696D\u3001\u7DA0\u80FD\u79D1\u6280\u53CA\u667A\u6167\u8FB2\u696D\u3002\u5B78\u6821\u4EE5\u300C\u5353\u8D8A\u6559\u5B78\u3001\u52D9\u5BE6\u7814\u7A76\u300D\u70BA\u5B9A\u4F4D\uFF0C\u671F\u8A31\u5B78\u751F\u4E00\u7562\u696D\u5C31\u80FD\u7ACB\u523B\u63A5\u8ECC\u696D\u754C\u3002\u6821\u8A13\u70BA\u300C\u7BE4\u5B78\u529B\u884C\u3001\u656C\u696D\u6A02\u7FA4\u300D\u3002\r\n\u8DE8\u57DF\u5B78\u7FD2\u8207\u6574\u5408\u5275\u65B0\uFF1A\u64C1\u6709\u56DB\u5927\u9818\u57DF\u5B78\u9662\uFF08\u4EBA\u6587\u53CA\u7BA1\u7406\u3001\u5DE5\u3001\u751F\u7269\u8CC7\u6E90\u3001\u96FB\u6A5F\u8CC7\u8A0A\uFF09\uFF0C\u7A4D\u6975\u5C0E\u5165\u65B0\u8208\u9818\u57DF\uFF0C\u8FD1\u5E74\u6210\u7ACB\u4E86\u591A\u500B\u7279\u8272\u5B78\u7A0B\uFF0C\u5982\u300C\u5927\u6578\u64DA\u7BA1\u7406\u8207\u61C9\u7528\u5B78\u58EB\u5B78\u4F4D\u5B78\u7A0B\u300D\u3001\u300C\u7121\u4EBA\u6A5F\u61C9\u7528\u66A8\u667A\u6167\u8FB2\u696D\u78A9\u58EB\u5B78\u4F4D\u5B78\u7A0B\u300D\u3001\u300C\u667A\u6167\u4F11\u9592\u8FB2\u696D\u9032\u4FEE\u5B78\u58EB\u5B78\u4F4D\u5B78\u7A0B\u300D\u7B49\uFF0C\u8B93\u5B78\u751F\u300C\u5B78\u4EE5\u81F4\u7528\u300D\u3002\r\n\u6C38\u7E8C\u5171\u69AE\u7406\u5FF5\uFF1A\u7531\u6821\u9577\u9673\u5A01\u620E\u79C9\u6301\u300C\u51DD\u805A\u5171\u8B58\u3001\u52D9\u5BE6\u9769\u65B0\u3001\u93C8\u7D50\u570B\u969B\u3001\u6C38\u7E8C\u5171\u69AE\u300D\u7684\u7406\u5FF5\uFF0C\u5C07\u5B9C\u862D\u5927\u5B78\u6253\u9020\u70BA\u6C38\u7E8C\u767C\u5C55\u7684\u7CBE\u7DFB\u578B\u7DA0\u8272\u7D9C\u5408\u5927\u5B78\uFF0C\u4E26\u7A4D\u6975\u63A8\u52D5\u57CE\u5357\u6821\u5340\u65C1\u7684\u79D1\u5B78\u5712\u5340\u5EE0\u5546\u8207\u5B9C\u5927\u9032\u884C\u6DF1\u5EA6\u7684\u7522\u5B78\u5408\u4F5C\u5BE6\u8E10\u3002\r\n\u4E8C\u3001
