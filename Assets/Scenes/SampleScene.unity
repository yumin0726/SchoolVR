    \u5B9C\u862D\u7E23\u5B9C\u862D\u5E02\u795E\u8FB2\u8DEF\u4E00\u6BB5 1 \u865F\r\n\u96FB\u8A71\uFF1A03-9357400\r\n\u7DB2\u5740\uFF1Ahttps://www.niu.edu.tw/\n\n\u5DE5\u5B78\u9662\u6709\u571F\u6728\u5DE5\u7A0B\u5B78\u7CFB\u3001\u74B0\u5883\u5DE5\u7A0B\u5B78\u7CFB\u3001\u6A5F\u68B0\u8207\u6A5F\u96FB\u5DE5\u7A0B\u5B78\u7CFB\u3001\u5316\u5B78\u5DE5\u7A0B\u8207\u6750\u6599\u5DE5\u7A0B\u5B78\u7CFB\u3001\u5EFA\u7BC9\u8207\u6C38\u7E8C\u898F\u5283\u7814\u7A76\u6240\u3001\u5DE5\u5B78\u9662\u78A9\u58EB\u5728\u8077\u5C08\u73ED\u3001\u667A\u6167\u6C38\u7E8C\u5DE5\u7A0B\u535A\u58EB\u73ED\r\n\u96FB\u6A5F\u8CC7\u8A0A\u5B78\u9662\u6709\u96FB\u6A5F\u5DE5\u7A0B\u5B78\u7CFB\u3001\u96FB\u5B50\u5DE5\u7A0B\u5B78\u7CFB\u3001\u8CC7\u8A0A\u5DE5\u7A0B\u5B78\u7CFB\u3001\u6578\u4F4D\u5B78\u7FD2\u78A9\u58EB\u5728\u8077\u5C08\u73ED\u3001\u96FB\u6A5F\u8CC7\u8A0A\u5B78\u9662\u78A9\u58EB\u5728\u8077\u5C08\u73ED\u3001\u4EBA\u5DE5\u667A\u6167\u78A9\u58EB\u5B78\u4F4D\u5B78\u7A0B\r\n\u751F\u7269\u8CC7\u6E90\u5B78\u9662\u6709\u5712\u85DD\u5B78\u7CFB\u3001\u98DF\u54C1\u79D1\u5B78\u7CFB\u3001\u751F\u7269\u6A5F\u96FB\u5DE5\u7A0B\u5B78\u7CFB\u3001\u68EE\u6797\u66A8\u81EA\u7136\u8CC7\u6E90\u5B78\u7CFB\u3001\u751F\u7269\u6280\u8853\u8207\u52D5\u7269\u79D1\u5B78\u7CFB\u3001\u751F\u7269\u8CC7\u6E90\u5B78\u9662\u539F\u4F4F\u6C11\u5C08\u73ED\u3001\u751F\u7269\u8CC7\u6E90\u5B78\u9662\u78A9\u58EB\u5728\u8077\u5C08\u73ED\u3001\u7121\u4EBA\u6A5F\u61C9\u7528\u66A8\u667A\u6167\u8FB2\u696D\u78A9\u58EB\u5B78\u4F4D\u5B78\u7A0B\u3001\u8FB2\u696D\u63A8\u5EE3\u59D4\u54E1\u6703\u3001\u5EF6\u6587\u5BE6\u9A57\u6797\u5834\u3001\u5BE6\u7FD2\u5834\u5340\u7BA1\u7406\u8207\u767C\u5C55\u4E2D\u5FC3\r\n\u4EBA\u6587\u53CA\u7BA1\u7406\u5B78\u9662\u6709\u5916\u570B\u8A9E\u6587\u5B78\u7CFB\u3001\u61C9\u7528\u7D93\u6FDF\u8207\u7BA1\u7406\u5B78\u7CFB\u3001\u4F11\u9592\u7522\u696D\u8207\u5065\u5EB7\u4FC3\u9032\u5B78\u7CFB\u3001\u9AD8\u968E\u7D93\u71DF\u7BA1\u7406\u78A9\u58EB\u5728\u8077\u5C08\u73ED
    (EMBA)\u3001\u667A\u6167\u4F11\u9592\u8FB2\u696D\u9032\u4FEE\u5B78\u58EB\u5B78\u4F4D\u5B78\u7A0B\u3001\u5927\u6578\u64DA\u7BA1\u7406\u8207\u61C9\u7528\u5B78\u58EB\u5B78\u4F4D\u5B78\u7A0B\r\n\u535A\u96C5\u5B78\u90E8\u6709\u8A9E\u8A00\u6559\u80B2\u4E2D\u5FC3\u3001\u901A\u8B58\u6559\u80B2\u4E2D\u5FC3\u3001\u904B\u52D5\u6559\u80B2\u4E2D\u5FC3\n\n\u68EE\u6797\u66A8\u81EA\u7136\u8CC7\u6E90\u5B78\u7CFB\r\n\r\n\u937E\u667A\u6615\r\n\u8077\u7A31\uFF1A\u526F\u6559\u6388\u517C\u7CFB\u4E3B\u4EFB\r\n\u7814\u7A76\u5C08\u9577\uFF1A\r\n\u80B2\u6797\u5B78\u3001\u6A39\u8F2A\u5B78\u3001\u751F\u614B\u8CC7\u6599\u7D71\u8A08\u5206\u6790\u3001\u7121\u4EBA\u6A5F\u61C9\u7528\u6280\u8853\u3001\u5F71\u50CF\u8655\u7406\u6280\u8853\r\n\r\n\u5353\u5FD7\u9686\r\n\u8077\u7A31\uFF1A\u6559\u6388\r\n\u7814\u7A76\u5C08\u9577\uFF1A\r\n\u6728\u6750\u9451\u5225\u3001\u6728\u6750\u6027\u8CEA\u3001\u6728\u8CEA\u74B0\u5883\u5B78\u3001\u6728\u6750\u7D50\u69CB\u5B78\r\n\r\n\u8521\u5448\u5947\r\n\u8077\u7A31\uFF1A\u6559\u6388\r\n\u7814\u7A76\u5C08\u9577\uFF1A\r\n\u571F\u58E4\u5F62\u614B\u5316\u80B2\u53CA\u5206\u985E\u3001\u571F\u58E4\u53CA\u74B0\u5883\u5316\u5B78\u3001\u571F\u58E4\u8ABF\u67E5\r\n\r\n\u5F35\u8CC7\u6B63\r\n\u8077\u7A31\uFF1A\u6559\u6388\r\n\u7814\u7A76\u5C08\u9577\uFF1A\r\n\u68EE\u6797\u7279\u7522\u7269\u3001\u6728\u6750\u4FDD\u5B58\u3001\u6728\u6750\u5857\u6599\u3001\u5929\u7136\u7279\u7528\u5316\u5B78\u54C1\r\n\r\n\r\n\u7F85\u76DB\u5CF0\r\n\u8077\u7A31\uFF1A\u526F\u6559\u6388\r\n\u7814\u7A76\u5C08\u9577\uFF1A\r\n\u751F\u7269\u8907\u5408\u6750\u6599\u3001
    \u6728\u8CEA\u6750\u6599\u6027\u8CEA\u53CA\u52A0\u5DE5\r\n\r\n\r\n\u90ED\u4F69\u923A\r\n\u8077\u7A31\uFF1A\u526F\u6559\u6388\r\n\u7814\u7A76\u5C08\u9577\uFF1A\r\n\u6728\u6750\u5316\u5B78\u3001\u751F\u7269\u6027\u9AD8\u5206\u5B50\u3001\u5948\u7C73\u7E96\u7DAD\u7D20\r\n\r\n\u9673\u7469\u9054
    \r\n\u8077\u7A31\uFF1A\u526F\u6559\u6388\r\n\u7814\u7A76\u5C08\u9577\uFF1A\r\n\u8CC7\u6E90\u898F\u5283\u8207\u7BA1\u7406\u3001\u793E\u5340\u6797\u696D\u3001\u68EE\u6797\u7D93\u71DF\u3001\u591A\u76EE\u6A19\u6C7A\u7B56\u3001\u6709\u6A5F\u8FB2\u5834\u7D93\u71DF\u7BA1\u7406\r\n\r\n\r\n\u6BDB\u4FCA\u5091\r\n\u8077\u7A31\uFF1A\u52A9\u7406\u6559\u6388\r\n\u7814\u7A76\u5C08\u9577\uFF1A\r\n\u91CE\u751F\u52D5\u7269\u65CF\u7FA4\u53CA\u7FA4\u805A\u751F\u614B\u5B78\u3001\u4FDD\u80B2\u751F\u7269\u5B78\u3001\u52D5\u7269\u8CC7\u6E90\u8ABF\u67E5\r\n\r\n\r\n\u962E\u5FE0\u4FE1\r\n\u8077\u7A31\uFF1A\u52A9\u7406\u6559\u6388\r\n\u7814\u7A76\u5C08\u9577\uFF1A\r\n\u7CFB\u7D71\u751F\u614B\u5B78\u3001\u80FD\u503C\u5206\u6790\u3001\u751F\u614B\u5DE5\u7A0B\u3001\u6FD5\u5730\u7CFB\u7D71\u8207\u7D93\u71DF\u3001\u9059\u611F\u63A2\u6E2C\r\n\r\n\r\n\u6797\u5950\u5B87\r\n\u8077\u7A31\uFF1A\u52A9\u7406\u6559\u6388\r\n\u7814\u7A76\u5C08\u9577\uFF1A\r\n\u68EE\u6797\u751F\u614B\u3001\u690D\u7FA4\u8ABF\u67E5\u8207\u5206\u985E\u3001\u6C23\u5019\u8B8A\u9077\u4E4B\u68EE\u6797\u9810\u6E2C\u6A21\u64EC\u8207\u885D\u64CA\u7814\u7A76\u3001\u6728\u7AF9\u6750\u8CC7\u6E90\u52D5\u614B\u8ABF\u67E5\u7814\u7A76\u3001\u690D\u7269\u591A\u6A23\u6027\u8207\u4FDD\u80B2\u7814\u7A76\r\n\r\n\r\n\u8B1D\u4F9D\u9054\r\n\u8077\u7A31\uFF1A\u52A9\u7406\u6559\u6388\r\n\u7814\u7A76\u5C08\u9577\uFF1A\r\n\u68EE\u6797\u6E2C\u91CF\u6E2C\u8A08\u5B78\u3001\u68EE\u6797\u822A\u9059\u6E2C\u3001\u516C\u79C1\u6709\u6797\u7D93\u71DF\u8F14\u5C0E\n\n\u9AD4\u80B2\u9928\u9928\u5167\u914D\u7F6E\uFF1A\u649E\u7403\u5834(B1)\u3001\u7C43\u7403\u5834(2F)\u3001\u6392\u7403\u5834(B1)\u3001\u6500\u5CA9\u5834(B1)\u3001\u7FBD\u7403\u5834(B1)\u3001\u7DB2\u7403\u5834(B1)\u3001\u91CD\u91CF\u8A13\u91CF\u5BA4(B1)\u3001\u5BA4\u5167\u8DD1\u9053(3F)\u3001\u821E\u8E48\u6559\u5BA4(1F)\n\n\u5716\u66F8\u9928\u9928\u5167\u914D\u7F6E:\n    
